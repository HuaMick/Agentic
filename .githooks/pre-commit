#!/usr/bin/env bash
# =============================================================================
# .githooks/pre-commit -- Story 29
# =============================================================================
#
# Pre-commit hook that refuses commits whose post-commit corpus state would
# render as drift per `agentic stories health --all` or `agentic stories audit`.
#
# Behaviour:
#   1. If `agentic` binary is not on PATH, emit a notice to stderr and exit 0
#      (fail open to avoid chicken-and-egg blocks on fresh clones).
#   2. Run `agentic stories audit`. Exit non-zero if it fails.
#   3. Run `agentic stories health --all`. Exit non-zero if it fails.
#   4. If both succeed, exit 0 silently.
#
# This hook is invoked by git with cwd set to the repository root.
# =============================================================================

# Check if `agentic` is on PATH. If not, fail open (exit 0) with a message.
if ! command -v agentic >/dev/null 2>&1; then
  printf 'notice: agentic binary not on PATH; skipping pre-commit hook. Install with: cargo install --path crates/agentic-cli --locked\n' >&2
  exit 0
fi

# Create temporary files for capturing output.
audit_output=$(mktemp)
health_output=$(mktemp)
trap 'rm -f "$audit_output" "$health_output"' EXIT

# Run audit and health commands. Use subshells to avoid exiting on failure.
audit_failed=0
health_failed=0

# Run audit command. Capture output, check exit status.
(agentic stories audit >"$audit_output" 2>&1) || audit_failed=1

# Run health command. Capture output, check exit status.
(agentic stories health --all >"$health_output" 2>&1) || health_failed=1

# If either command failed, emit error messages and exit non-zero.
if [[ "$audit_failed" -eq 1 ]] || [[ "$health_failed" -eq 1 ]]; then
  printf 'pre-commit hook: aborting commit due to corpus drift\n' >&2

  if [[ "$audit_failed" -eq 1 ]]; then
    printf '\n=== agentic stories audit failures ===\n' >&2
    cat "$audit_output" >&2 || true
  fi

  if [[ "$health_failed" -eq 1 ]]; then
    printf '\n=== agentic stories health --all failures ===\n' >&2
    cat "$health_output" >&2 || true
  fi

  exit 1
fi

# Both commands succeeded; permit the commit silently.
exit 0
