{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.dev/schemas/agent-inputs.schema.json",
  "title": "AgentInputs",
  "description": "What the agent reads, what tools it uses, what commands it prefers. Lives at agents/<category>/<name>/inputs.yml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["required_reading", "tools"],
  "properties": {
    "required_reading": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Files the agent reads at session start, every session. At least one entry. Use `reason: See agents/assets/guidelines/<file>.yml` when a shared guideline applies."
    },
    "context": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "reason"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Glob patterns the agent scans for background context. Not read in full; scanned on demand."
    },
    "parameters": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": { "type": "string", "minLength": 1 },
          "required_when": {
            "type": "string",
            "description": "Condition under which the parameter is required. Omit for 'always required'."
          }
        }
      },
      "description": "Caller-supplied inputs (e.g. story_id, objective)."
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["Read", "Glob", "Grep", "Write", "Edit", "Bash", "WebFetch", "WebSearch", "NotebookEdit"]
      },
      "description": "Claude Code tool grant. The base set is Read,Glob,Grep,Write,Edit,Bash — see agents/assets/definitions/tools-base.yml. Add only what the agent genuinely needs."
    },
    "commands": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "invocation_example": { "type": "string" },
          "purpose": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Preferred Bash commands the agent uses."
    }
  }
}
